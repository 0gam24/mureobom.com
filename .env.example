# 실제 .env는 .gitignore. 이 파일은 키 형태만 보여주는 템플릿.
# Cloudflare Pages 환경변수 UI에서도 동일하게 설정.

# ---- Naver 검색 API (토픽 스캐너) ----
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---- 검색엔진 사이트 검증 ----
PUBLIC_NAVER_SITE_VERIFICATION=
PUBLIC_GOOGLE_SITE_VERIFICATION=

# ---- Google Analytics 4 ----
# 형식: G-XXXXXXXXXX (src/layouts/Base.astro가 PUBLIC_GA_ID로 읽음)
PUBLIC_GA_ID=

# ---- Google AdSense ----
# 형식: ca-pub-XXXXXXXXXXXXXXXX
PUBLIC_ADSENSE_CLIENT=
# 슬롯 ID (각 ad unit의 data-ad-slot)
PUBLIC_ADSENSE_SLOT_TOP=
PUBLIC_ADSENSE_SLOT_BOTTOM=
