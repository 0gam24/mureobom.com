# мӢӨм ң .envлҠ” .gitignore. мқҙ нҢҢмқјмқҖ нӮӨ нҳ•нғңл§Ң ліҙм—¬мЈјлҠ” н…ңн”ҢлҰҝ.
# Cloudflare Pages нҷҳкІҪліҖмҲҳ UIм—җм„ңлҸ„ лҸҷмқјн•ҳкІҢ м„Өм •.

# ---- Naver кІҖмғү API (нҶ н”Ҫ мҠӨмәҗл„Ҳ) ----
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---- кІҖмғүм—”м§„ мӮ¬мқҙнҠё кІҖмҰқ ----
PUBLIC_NAVER_SITE_VERIFICATION=
PUBLIC_GOOGLE_SITE_VERIFICATION=

# ---- Google AdSense ----
# нҳ•мӢқ: ca-pub-XXXXXXXXXXXXXXXX
PUBLIC_ADSENSE_CLIENT=
# мҠ¬лЎҜ ID (к°Ғ ad unitмқҳ data-ad-slot)
PUBLIC_ADSENSE_SLOT_TOP=
PUBLIC_ADSENSE_SLOT_BOTTOM=
