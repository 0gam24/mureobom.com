---
import Base from "../../layouts/Base.astro";
import AdSlot from "../../components/AdSlot.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("answers");
  return posts.map((p)=>({ params:{ cluster:p.data.cluster, slug:p.slug }, props:{ p }}));
}
const { p } = Astro.props;
const { Content } = await p.render();
const CL: Record<string, string> = { tax:"세금", support:"정부지원금", loan:"대출·신용", insurance:"보험·연금" };
const fmt = (d: Date) => new Intl.DateTimeFormat("ko-KR",{dateStyle:"long"}).format(d);

/* internalLinks("cluster/slug")를 실제 '함께 보면 좋은 글' 링크로 해석 (CNT-01).
 * 발행 글 슬러그와 매칭 실패 항목은 조용히 건너뜀 — 빌드는 깨지지 않는다. */
const allPosts = await getCollection("answers");
const bySlug = new Map(allPosts.map((a) => [a.slug, a]));
const related = (p.data.internalLinks ?? [])
  .map((entry: string) => {
    const slug = entry.split("/").pop()?.toLowerCase() ?? "";
    const target = bySlug.get(slug);
    return target && target.slug !== p.slug
      ? { href: `/${target.data.cluster}/${target.slug}/`, title: target.data.title }
      : null;
  })
  .filter((x): x is { href: string; title: string } => x !== null);

/* FAQ 답변의 마크다운 링크/강조를 HTML로 — 평문 노출 방지 (Google FAQ rich result는 <a>·<strong> 허용) */
function faqHtml(text: string): string {
  return text
    .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, '<a href="$2">$1</a>');
}

/* Schema.org @graph — Article + FAQPage + BreadcrumbList 묶음.
 * Google가 권장하는 다중 타입 결합 방식. Base.astro가 단일 script로 직렬화. */
const siteBase = Astro.site?.toString().replace(/\/$/, "") ?? "";
/* 한글 슬러그 percent-encoding (canonical·@id·BreadcrumbList item 모두 통일) */
const pageUrl  = `${siteBase}/${p.data.cluster}/${encodeURIComponent(p.slug)}/`;
const clusterUrl = `${siteBase}/${p.data.cluster}/`;
const ogImage  = p.data.image
  ? `${siteBase}${p.data.image}`
  : `${siteBase}/og-default.png`;

/* datePublished/dateModified 분리 — published 미지정 글은 updated로 폴백 (SEO-04) */
const publishedDate = p.data.published ?? p.data.updated;

/* KST(+09:00) ISO 8601 — Google article.md: 시간대 명시 권장.
 * frontmatter date-only는 UTC 자정으로 파싱되므로 날짜 문자열만 취해 KST 자정으로 조립
 * (toISOString() UTC 표기 시 KST 발행일과 달력 날짜가 어긋나는 문제 방지). */
function toKstIso(d: Date | string): string {
  return `${new Date(d).toISOString().slice(0, 10)}T00:00:00+09:00`;
}
const publishedIso = toKstIso(publishedDate);
const modifiedIso  = toKstIso(p.data.updated);

/* 출처 링크 rel — 정부·공공기관(go.kr/or.kr/gov.kr/korea.kr)은 nofollow 제거(신뢰 출처 시그널),
 * 그 외 도메인은 nofollow 유지 (GAP-02) */
function sourceRel(url: string): string | undefined {
  try {
    const host = new URL(url).hostname;
    if (
      host.endsWith(".go.kr") || host.endsWith(".or.kr") ||
      host === "gov.kr" || host.endsWith(".gov.kr") ||
      host === "korea.kr" || host.endsWith(".korea.kr")
    ) return undefined;
  } catch { /* 비정상 URL은 보수적으로 nofollow */ }
  return "nofollow";
}

/* 확인한 공식 자료를 schema.org citation으로 노출 — E-E-A-T 신뢰 신호(GAP-03) */
const citations = (p.data.sources ?? [])
  .filter((s) => s.url)
  .map((s) => ({ "@type": "CreativeWork", "name": s.label, "url": s.url }));

const articleNode = {
  "@type": "Article",
  "headline": p.data.title,
  "description": p.data.summary,
  "inLanguage": "ko",
  "isAccessibleForFree": true,
  "datePublished": publishedIso,
  "dateModified":  modifiedIso,
  "image": [ogImage],
  "author":    { "@type": "Organization", "name": p.data.author, "url": siteBase ? `${siteBase}/about/` : undefined },
  "publisher": {
    "@type": "Organization",
    "@id": `${siteBase}/#organization`,   /* 홈 Organization 노드와 동일 식별자 — 참조 일관성 */
    "name": "물어봄",
    "url": siteBase || undefined,
    "logo": { "@type": "ImageObject", "url": `${siteBase}/apple-touch-icon.png` },
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  ...(citations.length ? { "citation": citations } : {}),
};

/* BreadcrumbList — 네이버·구글 겸용:
 * 네이버는 name에 "홈"·"top" 등 일반 단어 금지 + item을 {@id, name} 객체로 요구,
 * 구글은 두 형태 모두 인식(breadcrumb.md). 첫 항목명은 사이트명 "물어봄". */
const breadcrumbNode = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "물어봄",           "item": { "@id": `${siteBase}/`, "name": "물어봄" } },
    { "@type": "ListItem", "position": 2, "name": CL[p.data.cluster], "item": { "@id": clusterUrl, "name": CL[p.data.cluster] } },
    { "@type": "ListItem", "position": 3, "name": p.data.title,       "item": { "@id": pageUrl, "name": p.data.title } },
  ],
};

const faqNode = p.data.faq.length ? {
  "@type": "FAQPage",
  "mainEntity": p.data.faq.map((f)=>({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": faqHtml(f.a) },
  })),
} : null;

const jsonld = {
  "@context": "https://schema.org",
  "@graph": [articleNode, breadcrumbNode, ...(faqNode ? [faqNode] : [])],
};

/* AdSense slot IDs (compliance AD-04: 출처/FAQ 직접 인접 금지)
 *  - top: 요약과 본문 사이 (휴식 지점)
 *  - bottom: FAQ 끝 ↔ 고지 사이 (FAQ가 있을 때만 노출, 출처 박스와 분리됨) */
const slotTop    = import.meta.env.PUBLIC_ADSENSE_SLOT_TOP    ?? "";
const slotBottom = import.meta.env.PUBLIC_ADSENSE_SLOT_BOTTOM ?? "";
---
<Base
  title={p.data.title}
  description={p.data.summary}
  jsonld={jsonld}
  ogType="article"
  ogImage={ogImage}
  canonical={pageUrl}
  articlePublished={publishedIso}
  articleModified={modifiedIso}
>
  <article class="post">
    <p class="crumb"><a href={`/${p.data.cluster}/`}>{CL[p.data.cluster]}</a></p>
    <h1>{p.data.title}</h1>
    <p class="answer-now">{p.data.summary}</p>
    <div class="byline">
      <p class="by-who"><strong>{p.data.author}</strong> 작성 · 공식 1차 출처 대조 검수</p>
      <p class="by-meta">발행 {fmt(publishedDate)} · 최종 확인 {fmt(p.data.updated)} · 근거 {p.data.sources.length}건 · <a href="/about/#how">이 글은 어떻게 만드나요?</a></p>
    </div>

    <AdSlot slot={slotTop} label="top" />

    <div class="prose"><Content /></div>

    <aside class="sources">
      <h2>확인한 공식 자료</h2>
      <ul>
        {p.data.sources.map((s)=>(
          <li>{s.url ? <a href={s.url} rel={sourceRel(s.url)}>{s.label}</a> : s.label}</li>
        ))}
      </ul>
    </aside>

    {related.length>0 && (
      <nav class="related" aria-label="관련 글">
        <h2>함께 보면 좋은 글</h2>
        <ul>
          {related.map((r)=>(
            <li><a href={r.href}>{r.title}</a></li>
          ))}
        </ul>
      </nav>
    )}

    {p.data.faq.length>0 && (
      <section class="faq">
        <h2>자주 묻는 질문</h2>
        {p.data.faq.map((f)=>(
          <details>
            <summary>{f.q}</summary>
            <p set:html={faqHtml(f.a)} />
          </details>
        ))}
      </section>
    )}

    {p.data.faq.length>0 && <AdSlot slot={slotBottom} label="bottom" />}

    {p.data.disclaimer && (
      <p class="disc">※ 일반 정보 제공 목적입니다. 개별 사안은 관할 기관·전문가 확인을 권합니다.</p>
    )}

    <ShareButtons url={pageUrl} title={p.data.title} />
  </article>

  <style>
    .post{max-width:760px;margin:3rem auto;padding:0 var(--gap);}
    .crumb{font-size:var(--fs-meta);font-weight:600;}
    .post h1{font-size:var(--fs-h1);margin:.7rem 0 1.2rem;}
    .answer-now{font-size:var(--fs-lead);background:var(--teal-wash);
      border-left:3px solid var(--teal);padding:1rem 1.2rem;border-radius:0 var(--r-sm) var(--r-sm) 0;
      color:var(--ink);}
    .byline{margin:1rem 0 2.4rem;font-size:var(--fs-meta);
      border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:.8rem 0;}
    .byline .by-who{color:var(--ink-soft);}
    .byline .by-who strong{color:var(--ink);font-weight:600;}
    .byline .by-meta{color:var(--ink-faint);margin-top:.25rem;}
    .prose{max-width:var(--measure);}
    .prose :global(h2){font-size:var(--fs-h2);margin:2.4rem 0 .9rem;}
    .prose :global(p){margin:1rem 0;color:var(--ink);}
    .prose :global(table){width:100%;border-collapse:collapse;margin:1.4rem 0;font-size:.95rem;
      display:block;overflow-x:auto;max-width:100%;}
    .prose :global(th),.prose :global(td){border:1px solid var(--line);padding:.6rem .8rem;text-align:left;}
    .prose :global(th){background:var(--paper-2);}
    /* 인포그래픽/다이어그램 — /diagrams/{slug}.svg 를 figure 또는 단독 img로 삽입 */
    .prose :global(figure){margin:1.8rem 0;}
    .prose :global(figure img),.prose :global(p > img){display:block;max-width:100%;height:auto;
      margin:.4rem auto 0;background:var(--paper-2);border:1px solid var(--line);
      border-radius:var(--r-md);padding:1rem;}
    .prose :global(figcaption){text-align:center;font-size:var(--fs-meta);
      color:var(--ink-faint);margin-top:.6rem;}
    .sources{margin:3rem 0;background:var(--paper-2);border:1px solid var(--line);
      border-radius:var(--r-md);padding:1.4rem 1.6rem;}
    .sources h2{font-size:1.15rem;margin-bottom:.7rem;}
    .sources ul{padding-left:1.1rem;color:var(--ink-soft);font-size:.95rem;}
    .sources li{margin:.35rem 0;}
    .related{margin:3rem 0;}
    .related h2{font-size:var(--fs-h2);margin-bottom:.8rem;}
    .related ul{padding-left:1.1rem;font-size:.97rem;}
    .related li{margin:.45rem 0;}
    .faq{margin:3rem 0;}
    .faq h2{font-size:var(--fs-h2);margin-bottom:1rem;}
    .faq details{border-bottom:1px solid var(--line);padding:1rem 0;}
    .faq summary{font-weight:600;cursor:pointer;list-style:none;}
    .faq summary::before{content:"+";color:var(--teal);margin-right:.6rem;font-weight:700;}
    .faq details[open] summary::before{content:"–";}
    .faq p{margin-top:.7rem;color:var(--ink-soft);}
    .disc{margin-top:2.5rem;font-size:var(--fs-meta);color:var(--ink-faint);
      border-top:1px solid var(--line);padding-top:1rem;}
  </style>
</Base>
