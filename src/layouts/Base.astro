---
import "../styles/tokens.css";
/* 폰트 셀프호스팅 — @fontsource(한국어 unicode-range 서브셋 woff2, font-display: swap).
 * Google Fonts CDN 왕복(DNS+TLS) 제거 + /_astro/* immutable 캐시 적용 (C3 폰트 최적화). */
import "@fontsource/gowun-batang/400.css";
import "@fontsource/gowun-batang/700.css";
import "@fontsource/ibm-plex-sans-kr/400.css";
import "@fontsource/ibm-plex-sans-kr/500.css";
import "@fontsource/ibm-plex-sans-kr/600.css";
/* Base props
 *  - title, description: 필수
 *  - jsonld: 페이지가 만든 schema.org 객체 (단일 또는 @graph)
 *  - ogType: "website" (기본) / "article" (글 상세에서 override)
 *  - ogImage: 절대 URL. 미지정 시 /og-default.png
 *  - canonical: 절대 URL. 미지정 시 Astro.url 기반 자동
 *  - fullTitle: true면 title을 그대로 <title>로 사용(브랜드 접미사 없음 — 홈 전용)
 *  - articlePublished/articleModified: article og 메타(ISO 8601) — 글 상세 전용
 */
const { title, description, jsonld, ogType = "website", ogImage, canonical,
        fullTitle = false, articlePublished, articleModified } = Astro.props;
const CLUSTERS = [
  { id: "tax", label: "세금", path: "/tax/" },
  { id: "support", label: "정부지원금", path: "/support/" },
  { id: "loan", label: "대출·신용", path: "/loan/" },
  { id: "insurance", label: "보험·연금", path: "/insurance/" },
];
/* env-only IDs (compliance AD-07) */
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const naverVerify   = import.meta.env.PUBLIC_NAVER_SITE_VERIFICATION;
const googleVerify  = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

/* Google Analytics 4 — 측정 ID는 시크릿 아님(소스에 노출됨).
 * env 우선, 없으면 코드 상 기본 ID 사용. Cloudflare Pages env에 PUBLIC_GA_ID 설정 시 거기서 읽음. */
const gaId = import.meta.env.PUBLIC_GA_ID ?? "G-HRWLK7NCKE";

/* URL 정규화: 한글 슬러그 percent-encoding 통일 (SEO 검토 #2 대응)
 *  - `new URL().toString()`은 path 부분 한글을 raw로 유지하므로 별도 인코딩 필요.
 *  - encodeURI는 `/` `.` `-` 같은 reserved 문자를 보존하면서 한글만 인코딩.
 *  - canonical과 og:url 둘 다 같은 인코딩 결과 사용 → sitemap.xml과도 일관. */
function toAbsoluteUrl(path: string): string {
  const encoded = encodeURI(path);
  if (Astro.site) return new URL(encoded, Astro.site).toString();
  return encoded;
}
const canonicalUrl = canonical ?? toAbsoluteUrl(Astro.url.pathname);

/* og:image: PNG 기본 — SNS 미리보기 호환 (SEO 검토 #3 대응).
 *  - og-default.png는 운영자가 1200×630으로 생성 후 public/에 배치.
 *  - 미생성 시 발행 글 OG 썸네일 깨짐 → finalize 작업 알림.
 *  - 글 frontmatter `image` 필드로 글별 OG override 가능. */
const ogImageUrl = ogImage ? toAbsoluteUrl(ogImage)
                           : toAbsoluteUrl("/og-default.png");
const siteName = "물어봄";
const pageTitle = fullTitle ? title : `${title} — ${siteName}`;

/* Cloudflare Pages 프리뷰 배포(*.pages.dev 브랜치 프리뷰)는 noindex —
 * 프로덕션(main)만 색인 허용. CF가 프리뷰에 X-Robots-Tag를 붙이지만 메타로 이중 안전. */
const cfBranch = process.env.CF_PAGES_BRANCH;
const isPreview = !!cfBranch && cfBranch !== "main";
const robotsContent = isPreview
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large";

/* 파비콘 — 네이버 요건: href는 상대 경로가 아닌 절대 경로, 동일 rel 값은 1개만 */
const faviconUrl = toAbsoluteUrl("/favicon.svg");
const appleTouchUrl = toAbsoluteUrl("/apple-touch-icon.png");
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robotsContent} />
  <meta name="theme-color" content="#0E7C72" />
  <link rel="canonical" href={canonicalUrl} />

  {/* Open Graph */}
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="ko_KR" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={title} />
  {ogType === "article" && articlePublished && (
    <meta property="article:published_time" content={articlePublished} />
  )}
  {ogType === "article" && articleModified && (
    <meta property="article:modified_time" content={articleModified} />
  )}

  {/* Twitter Card */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  {/* 구독 피드 — 브라우저·피드 리더 자동 감지용 (전체 목록은 /feeds/) */}
  <link rel="alternate" type="application/rss+xml" title="물어봄 RSS" href="/rss.xml" />
  <link rel="alternate" type="application/atom+xml" title="물어봄 Atom" href="/atom.xml" />
  <link rel="alternate" type="application/feed+json" title="물어봄 JSON Feed" href="/feed.json" />

  {/* Favicons — 네이버 요건: 절대 경로 필수, 동일 rel 1개만. 루트 /favicon.ico는 브라우저 자동 폴백.
   *  favicon.ico는 scripts/gen_favicon_ico.py, apple-touch-icon.png는 scripts/gen_apple_touch_icon.py로 생성 */}
  <link rel="icon" href={faviconUrl} type="image/svg+xml" />
  <link rel="apple-touch-icon" href={appleTouchUrl} />

  {/* Site verification */}
  {naverVerify  && <meta name="naver-site-verification"  content={naverVerify} />}
  {googleVerify && <meta name="google-site-verification" content={googleVerify} />}

  {jsonld && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonld)} />}
  {adsenseClient && (
    <script is:inline async crossorigin="anonymous"
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
    />
  )}

  {/* Google Analytics 4 (gtag.js) — 유휴 시점 로드(INP·메인스레드 보호).
   *  dataLayer 큐를 먼저 세워 이벤트 유실 없이 gtag.js만 지연 주입. */}
  {gaId && (
    <script is:inline define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
      (function(){
        var load = function(){
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
          document.head.appendChild(s);
        };
        if ('requestIdleCallback' in window) requestIdleCallback(load, {timeout: 3000});
        else setTimeout(load, 1500);
      })();
    </script>
  )}
</head>
<body>
  <a class="skip-link" href="#main">본문으로 건너뛰기</a>
  <header class="site-head">
    <a class="brand" href="/">물어<span class="bom">봄</span><i class="sprout" aria-hidden="true"></i></a>
    <nav class="nav">
      {CLUSTERS.map((c) => <a href={c.path}>{c.label}</a>)}
    </nav>
  </header>

  <main id="main"><slot /></main>

  <footer class="site-foot">
    <p>물어봄 — 공식 자료 기반 금융·생활 답변</p>
    <p class="foot-nav"><a href="/about/">소개</a> · <a href="/privacy/">개인정보처리방침</a> · <a href="/feeds/">구독</a></p>
    <p class="fine">본 콘텐츠는 일반 정보 제공 목적이며 개별 상황에 대한 법률·세무·금융 자문이 아닙니다.
      페이지에는 Google AdSense 광고가 노출될 수 있으며, 광고 수익은 사이트 운영에 사용됩니다.</p>
  </footer>

  <style>
    /* 스킵 링크 — 평시 화면 밖, 키보드 포커스 시 노출 (WCAG 2.4.1) */
    .skip-link{position:absolute;left:-9999px;top:0;z-index:100;
      background:var(--teal);color:#fff;padding:.6rem 1rem;border-radius:0 0 var(--r-sm) 0;
      font-weight:600;}
    .skip-link:focus{left:0;}
    .site-head{display:flex;align-items:center;justify-content:space-between;
      max-width:var(--maxw);margin:0 auto;padding:1.4rem var(--gap);}
    .brand{font-family:var(--font-display);font-size:1.5rem;font-weight:700;
      color:var(--ink);display:inline-flex;align-items:baseline;gap:.1rem;}
    .brand .bom{color:var(--teal);}
    .sprout{width:7px;height:7px;border-radius:0 70% 70% 70%;
      background:var(--teal);transform:rotate(45deg);margin-left:4px;display:inline-block;}
    .nav{display:flex;gap:1.4rem;font-size:.95rem;font-weight:500;}
    .nav a{color:var(--ink-soft);}
    .nav a:hover{color:var(--teal);}
    .site-foot{max-width:var(--maxw);margin:5rem auto 3rem;padding:2rem var(--gap) 0;
      border-top:1px solid var(--line);color:var(--ink-faint);font-size:var(--fs-meta);}
    .site-foot .foot-nav{margin-top:.4rem;}
    .site-foot .foot-nav a{color:var(--ink-soft);}
    .site-foot .foot-nav a:hover{color:var(--teal);}
    .site-foot .fine{margin-top:.4rem;}
    @media(max-width:600px){.nav{gap:.9rem;font-size:.85rem;}}
  </style>
</body>
</html>
